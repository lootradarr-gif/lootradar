// LootRadar veri modeli — Neon Postgres (serverless). Prisma.
// db push ile şema uygulanır (migration klasörü yok; erken aşama).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum GameStatus {
  MAINNET
  TGE
  BETA
  PRE_TOKEN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BoostStatus {
  PENDING_PAYMENT // bid oluşturuldu, on-chain ödeme bekleniyor
  QUEUED          // ödendi, sırada (daha yüksek bid yayında)
  LIVE            // şu an site-genelinde yayında
  CONSUMED        // impression'ları tükendi
  CANCELLED       // kullanıcı/iptal
  REJECTED        // admin reddetti / ödeme doğrulanamadı
}

model Game {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  ticker       String       @default("")
  genre        String       @default("other")
  desc         String       @default("")
  icon         String       @default("🎮") // emoji fallback
  iconUrl      String?      // proje logosu (data URL veya http)
  bannerUrl    String?      // kart arkaplanı / kapak görseli
  status       GameStatus   @default(PRE_TOKEN)
  chain        String       @default("solana")
  tokenAddress String?      // dolu → DexScreener canlı veri
  x            String?
  site         String?
  playersOnline Int         @default(0)
  holders      Int          @default(0)
  rating       Int          @default(0)
  // token yoksa gösterilecek demo market değerleri (tokenAddress varsa DexScreener kazanır)
  mockPrice    Float?
  mockMcap     Float?
  mockVol24h   Float?
  mockChange24h Float?
  reviewStatus ReviewStatus @default(PENDING)
  submitterWallet String?
  contact      String       @default("")
  featured     Boolean      @default(false) // öne çıkarma (admin manuel VEYA boost)
  featuredUntil DateTime?                   // boost bitiş zamanı (null = süresiz/admin)
  sortWeight   Int          @default(0)     // admin sıralama
  seed         Boolean      @default(false) // ilk tohum kayıtları
  voteCount    Int          @default(0) // community oyları
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  boosts       Boost[]
  events       Event[]
  posts        Post[]
  votes        Vote[]

  @@index([reviewStatus])
  @@index([status])
}

model Boost {
  id               String      @id @default(cuid())
  game             Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId           String
  bidderWallet     String
  bidSolPer1k      Float       // SOL / 1000 impression
  impressions      Int         // satın alınan toplam impression
  impressionsServed Int        @default(0)
  paidSol          Float       @default(0)
  status           BoostStatus @default(PENDING_PAYMENT)
  txSignature      String?     @unique
  createdAt        DateTime    @default(now())
  activatedAt      DateTime?
  endedAt          DateTime?

  @@index([status, bidSolPer1k])
  @@index([gameId])
}

// Sosyal katman kullanıcısı — kimlik = Solana cüzdanı (SIWS imzalı giriş).
model User {
  wallet      String   @id                    // Solana adresi (PK)
  displayName String?
  avatarUrl   String?                          // data URL veya http
  bio         String   @default("")
  xp          Int      @default(0)
  level       Int      @default(1)
  banned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]
  comments    Comment[]

  @@index([xp])
}

// Community postu (X-tarzı). Yazar = User (cüzdan).
model Post {
  id           String     @id @default(cuid())
  authorWallet String
  author       User       @relation(fields: [authorWallet], references: [wallet], onDelete: Cascade)
  text         String
  imageUrl     String?
  gameId       String?    // opsiyonel etiketlenen oyun
  game         Game?      @relation(fields: [gameId], references: [id], onDelete: SetNull)
  likeCount    Int        @default(0)
  commentCount Int        @default(0)
  pinned       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  comments     Comment[]
  likes        PostLike[]

  @@index([createdAt])
  @@index([authorWallet])
}

model Comment {
  id           String   @id @default(cuid())
  postId       String
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorWallet String
  author       User     @relation(fields: [authorWallet], references: [wallet], onDelete: Cascade)
  text         String
  createdAt    DateTime @default(now())

  @@index([postId])
}

model PostLike {
  postId    String
  wallet    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([postId, wallet])
}

// Günlük oyun oyu (1/gün). day = YYYY-MM-DD (UTC).
model Vote {
  id          String   @id @default(cuid())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  voterWallet String
  day         String
  createdAt   DateTime @default(now())

  @@unique([voterWallet, day])
  @@index([gameId])
}

// XP defteri — günlük cap + airdrop denetimi.
model XpLog {
  id        String   @id @default(cuid())
  wallet    String
  amount    Int
  reason    String   // post | comment | vote | like_received | daily
  day       String
  createdAt DateTime @default(now())

  @@index([wallet, day, reason])
}

model Event {
  id        String   @id @default(cuid())
  game      Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  gameId    String?
  gameName  String   @default("") // gameId yoksa serbest metin
  title     String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
